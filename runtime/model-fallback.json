{
  "description": "Edit primary/fallback models to match your accounts. Ollama tags: run `ollama list`. Keys never go in this file — use env vars.",
  "enabled": true,
  "primary": {
    "provider": "openai",
    "model": "gpt-5.4",
    "base_url": "https://api.openai.com/v1",
    "api_key_env": "OPENAI_API_KEY",
    "timeout_seconds": 120,
    "max_completion_tokens": 4096
  },
  "fallback": {
    "provider": "ollama",
    "model": "gemma2:2b",
    "base_url": "http://127.0.0.1:11434",
    "timeout_seconds": 120
  },
  "fallback_on": [
    "insufficient_quota",
    "billing_hard_limit_reached",
    "rate_limit",
    "timeout",
    "connection_error",
    "provider_unavailable",
    "server_error"
  ],
  "do_not_fallback_on": [
    "bad_request",
    "prompt_error",
    "tool_schema_error",
    "safety_refusal",
    "content_policy",
    "authentication_error",
    "unknown"
  ]
}
