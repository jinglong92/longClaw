{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://longclaw.dev/schemas/multi-agent.schema.v0.1.json",
  "title": "longClaw Multi-Agent Config v0.1",
  "type": "object",
  "required": [
    "version",
    "profile_name",
    "compatibility_mode",
    "controller",
    "specialists",
    "routing",
    "risk_audit",
    "output_visibility"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "profile_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "compatibility_mode": {
      "type": "string",
      "enum": ["openclaw_v1"]
    },
    "controller": {
      "type": "object",
      "required": ["id", "default_mode", "max_parallel_specialists", "must_finalize"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "const": "CTRL"
        },
        "default_mode": {
          "type": "string",
          "enum": ["single_specialist", "auto_route"]
        },
        "max_parallel_specialists": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "must_finalize": {
          "type": "boolean"
        }
      }
    },
    "specialists": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["id", "enabled", "domain"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "enum": ["LIFE", "JOB", "WORK", "PARENT", "LEARN", "MONEY", "BRO", "SIS"]
          },
          "enabled": {
            "type": "boolean"
          },
          "domain": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "required": ["parallel_limit", "triggers"],
      "additionalProperties": false,
      "properties": {
        "parallel_limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "keywords", "route"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 60
              },
              "keywords": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 40
                }
              },
              "route": {
                "type": "array",
                "minItems": 1,
                "maxItems": 2,
                "items": {
                  "type": "string",
                  "enum": ["LIFE", "JOB", "WORK", "PARENT", "LEARN", "MONEY", "BRO", "SIS"]
                }
              }
            }
          }
        }
      }
    },
    "risk_audit": {
      "type": "object",
      "required": ["enabled", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "required_fields": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "enum": ["core_gap", "tail_risk", "falsifier"]
          }
        }
      }
    },
    "output_visibility": {
      "type": "object",
      "required": ["show_routing", "routing_format"],
      "additionalProperties": false,
      "properties": {
        "show_routing": {
          "type": "boolean",
          "const": true
        },
        "routing_format": {
          "type": "string",
          "const": "User -> CTRL -> [ROLE] -> CTRL -> User"
        }
      }
    }
  }
}
