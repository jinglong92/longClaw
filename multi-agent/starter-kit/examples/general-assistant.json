{
  "version": "0.1",
  "profile_name": "general-assistant",
  "compatibility_mode": "openclaw_v1",
  "controller": {
    "id": "CTRL",
    "default_mode": "auto_route",
    "max_parallel_specialists": 2,
    "must_finalize": true
  },
  "specialists": [
    { "id": "LIFE", "enabled": true, "domain": "life operations" },
    { "id": "JOB", "enabled": true, "domain": "job search" },
    { "id": "WORK", "enabled": true, "domain": "workplace strategy" },
    { "id": "PARENT", "enabled": true, "domain": "parenting" },
    { "id": "LEARN", "enabled": true, "domain": "learning" },
    { "id": "MONEY", "enabled": true, "domain": "finance" },
    { "id": "BRO", "enabled": true, "domain": "casual chat" },
    { "id": "SIS", "enabled": true, "domain": "female perspective" }
  ],
  "routing": {
    "parallel_limit": 2,
    "triggers": [
      { "name": "life", "keywords": ["日程", "出行", "家务"], "route": ["LIFE"] },
      { "name": "job", "keywords": ["求职", "简历", "面试"], "route": ["JOB"] },
      { "name": "work", "keywords": ["晋升", "管理", "沟通"], "route": ["WORK"] },
      { "name": "parent", "keywords": ["孩子", "育儿", "亲子"], "route": ["PARENT"] },
      { "name": "learn", "keywords": ["学习", "复盘", "论文"], "route": ["LEARN"] },
      { "name": "money", "keywords": ["预算", "理财", "保险"], "route": ["MONEY"] },
      { "name": "chat", "keywords": ["闲聊", "吐槽", "放松"], "route": ["BRO"] },
      { "name": "relationship", "keywords": ["女性视角", "关系", "沟通"], "route": ["SIS"] },
      { "name": "job-parent-conflict", "keywords": ["面试", "接娃", "冲突"], "route": ["JOB", "PARENT"] }
    ]
  },
  "risk_audit": {
    "enabled": true,
    "required_fields": ["core_gap", "tail_risk"]
  },
  "output_visibility": {
    "show_routing": true,
    "routing_format": "User -> CTRL -> [ROLE] -> CTRL -> User"
  }
}
