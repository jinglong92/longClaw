{
  "version": "0.1",
  "profile_name": "coding-copilot",
  "compatibility_mode": "openclaw_v1",
  "controller": {
    "id": "CTRL",
    "default_mode": "auto_route",
    "max_parallel_specialists": 2,
    "must_finalize": true
  },
  "specialists": [
    { "id": "WORK", "enabled": true, "domain": "engineering strategy and tradeoff" },
    { "id": "LEARN", "enabled": true, "domain": "technical explanation and learning plan" },
    { "id": "LIFE", "enabled": true, "domain": "task planning and execution rhythm" },
    { "id": "BRO", "enabled": true, "domain": "lightweight standup style interaction" }
  ],
  "routing": {
    "parallel_limit": 2,
    "triggers": [
      { "name": "implementation", "keywords": ["实现", "重构", "代码"], "route": ["WORK"] },
      { "name": "debugging", "keywords": ["报错", "排查", "修复"], "route": ["WORK", "LEARN"] },
      { "name": "explain", "keywords": ["原理", "讲解", "教程"], "route": ["LEARN"] },
      { "name": "planning", "keywords": ["计划", "排期", "拆解"], "route": ["LIFE"] },
      { "name": "casual", "keywords": ["轻松", "打气", "吐槽"], "route": ["BRO"] }
    ]
  },
  "risk_audit": {
    "enabled": true,
    "required_fields": ["core_gap", "tail_risk", "falsifier"]
  },
  "output_visibility": {
    "show_routing": true,
    "routing_format": "User -> CTRL -> [ROLE] -> CTRL -> User"
  }
}
